rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'abuqitmirshirazalmadani@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    match /submissions/{submissionId} {
      allow create: if isValidId(submissionId) && isValidSubmission(incoming());
      allow read: if isAdmin();
      allow update, delete: if false; // Submissions are immutable once sent
    }
  }
}
